# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_16chars
RECIPIENT_EMAIL=recipient@example.com

# ── Optional: Gemini model overrides (leave blank to use defaults) ─────────────
# GEMINI_MODEL=gemini-3.1-flash-lite-preview
# SCORE_MODEL=gemini-3.1-flash-lite-preview
# TRANSLATE_MODEL=gemini-3.1-flash-lite-preview
# SUMMARY_MODEL=gemini-3.1-flash-lite-preview
# WATCHLIST_MODEL=gemini-3.1-flash-lite-preview
